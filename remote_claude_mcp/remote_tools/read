#!/usr/bin/env python3
"""Read a file in cat -n format (line_number<tab>content).

Matches Claude Code's local Read tool behavior:
- offset: line number to start reading from (0 = beginning, 1-based otherwise)
- limit: max number of lines to read (default 2000)
- Output: "N\tcontent" per line, including trailing empty line after final newline
"""
import os
import sys


def main():
    if len(sys.argv) < 2:
        print("Usage: read <file> [--offset N] [--limit N]", file=sys.stderr)
        sys.exit(1)

    file_path = sys.argv[1]
    offset = None  # None = not specified, default to 1-based
    limit = 2000

    args = sys.argv[2:]
    i = 0
    while i < len(args):
        if args[i] == "--offset" and i + 1 < len(args):
            offset = int(args[i + 1])  # explicitly provided
            i += 2
        elif args[i] == "--limit" and i + 1 < len(args):
            limit = int(args[i + 1])
            i += 2
        else:
            i += 1

    if not os.path.exists(file_path):
        print(f"File does not exist: {file_path}", file=sys.stderr)
        sys.exit(1)

    if os.path.isdir(file_path):
        print(f"Path is a directory, not a file: {file_path}", file=sys.stderr)
        sys.exit(1)

    if not os.access(file_path, os.R_OK):
        print(f"Permission denied: {file_path}", file=sys.stderr)
        sys.exit(1)

    if os.path.getsize(file_path) == 0:
        total = 0
        try:
            with open(file_path) as f:
                total = sum(1 for _ in f)
        except Exception:
            pass
        print(f"Warning: the file exists but has empty contents. The file has {total} lines.")
        return

    try:
        with open(file_path) as f:
            content = f.read()
    except Exception as e:
        print(f"Error reading file: {e}", file=sys.stderr)
        sys.exit(1)

    # Split into lines preserving the trailing empty element after final \n
    # "a\nb\n".split("\n") → ["a", "b", ""] — the empty string represents the line after \n
    lines = content.split("\n")

    # offset semantics (matches local Read tool):
    # Not specified (None): start from beginning, number lines from 1
    # offset=0: start from beginning, number lines from 0
    # offset=N: start from line N (1-based), number from N
    if offset is None:
        start = 0
        start_num = 1
    elif offset == 0:
        start = 0
        start_num = 0
    else:
        start = offset - 1  # convert 1-based to 0-based index
        start_num = offset
    end = start + limit

    for i, idx in enumerate(range(start, min(end, len(lines)))):
        line_no = start_num + i
        print(f"{line_no}\t{lines[idx]}")


if __name__ == "__main__":
    main()
