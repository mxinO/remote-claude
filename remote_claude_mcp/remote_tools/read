#!/usr/bin/env python3
"""Read a file in cat -n format (line_number<tab>content)."""
import json
import os
import sys


def main():
    if len(sys.argv) < 2:
        print("Usage: read <file> [--offset N] [--limit N]", file=sys.stderr)
        sys.exit(1)

    file_path = sys.argv[1]
    offset = 0
    limit = 2000

    args = sys.argv[2:]
    i = 0
    while i < len(args):
        if args[i] == "--offset" and i + 1 < len(args):
            offset = int(args[i + 1])
            i += 2
        elif args[i] == "--limit" and i + 1 < len(args):
            limit = int(args[i + 1])
            i += 2
        else:
            i += 1

    if not os.path.exists(file_path):
        print(f"File does not exist: {file_path}", file=sys.stderr)
        sys.exit(1)

    if os.path.isdir(file_path):
        print(f"Path is a directory, not a file: {file_path}", file=sys.stderr)
        sys.exit(1)

    if not os.access(file_path, os.R_OK):
        print(f"Permission denied: {file_path}", file=sys.stderr)
        sys.exit(1)

    if os.path.getsize(file_path) == 0:
        total = 0
        try:
            with open(file_path) as f:
                total = sum(1 for _ in f)
        except Exception:
            pass
        print(f"Warning: the file exists but has empty contents. The file has {total} lines.")
        return

    try:
        with open(file_path) as f:
            for _ in range(offset):
                if f.readline() == "":
                    break
            for i in range(limit):
                line = f.readline()
                if line == "":
                    break
                # cat -n format: number<tab>content (no trailing newline on last line if file lacks it)
                line_no = offset + i + 1
                if line.endswith("\n"):
                    print(f"{line_no}\t{line[:-1]}")
                else:
                    print(f"{line_no}\t{line}", end="")
    except Exception as e:
        print(f"Error reading file: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
