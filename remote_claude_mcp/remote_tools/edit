#!/usr/bin/env python3
"""Edit a file with exact string replacement. Reads old/new/options from stdin as JSON."""
import json
import sys


def main():
    if len(sys.argv) < 2:
        print("Usage: edit <file>  (reads JSON from stdin: {old, new, replace_all})", file=sys.stderr)
        sys.exit(1)

    file_path = sys.argv[1]

    try:
        data = json.loads(sys.stdin.read())
    except (json.JSONDecodeError, ValueError) as e:
        print(f"Invalid JSON input: {e}", file=sys.stderr)
        sys.exit(1)

    old_string = data.get("old", "")
    new_string = data.get("new", "")
    replace_all = data.get("replace_all", False)

    if not old_string:
        print(json.dumps({"error": "old_string is empty."}))
        return

    if old_string == new_string:
        print(json.dumps({"error": "old_string and new_string must be different."}))
        return

    try:
        with open(file_path, "r") as f:
            content = f.read()
    except FileNotFoundError:
        print(json.dumps({"error": f"File does not exist: {file_path}"}))
        return
    except PermissionError:
        print(json.dumps({"error": f"Permission denied: {file_path}"}))
        return

    count = content.count(old_string)
    if count == 0:
        print(json.dumps({"error": "old_string not found in file."}))
        return

    if count > 1 and not replace_all:
        print(json.dumps({
            "error": f"Found {count} matches of the string to replace, but replace_all "
                     f"is false. To replace all occurrences, use --replace-all. To replace "
                     f"only one, provide more context to uniquely identify the instance."
        }))
        return

    if replace_all:
        new_content = content.replace(old_string, new_string)
        replacements = count
    else:
        new_content = content.replace(old_string, new_string, 1)
        replacements = 1

    try:
        with open(file_path, "w") as f:
            f.write(new_content)
    except PermissionError:
        print(json.dumps({"error": f"Permission denied writing to: {file_path}"}))
        return

    print(json.dumps({"ok": True, "replacements": replacements}))


if __name__ == "__main__":
    main()
